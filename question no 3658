class Solution {
    public int gcdOfOddEvenSums(int n) {
        int i;
        int sumodd = 0;
        int sumeven = 0;
        
        for(i = 1;i<=2*n;i = i + 2){
            sumodd = sumodd + i;
        }
        for(i = 0 ;i<2*n;i=i+2){
            sumeven = sumeven + i;
        }
            while(sumeven!=0){
               int rem = sumodd%sumeven ;
               sumodd = sumeven;
               sumeven = rem;
            }
            return sumodd;

    }
}
